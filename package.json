{
  "name": "petsystemcrm-api",
  "version": "1.0.0",
  "description": "Multi-tenant CRM API for pet shops",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main/index.ts",
    "build": "tsc",
    "start": "node dist/main/index.js",
    "migrate": "node dist/infra/database/migrate.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@fission-ai/openspec": "^1.3.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  }
}
