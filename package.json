{
	"name": "petsystemcrm-api",
	"version": "1.2.2",
	"description": "Multi-tenant CRM API for pet shops",
	"main": "dist/main/index.js",
	"scripts": {
		"dev": "tsx watch --env-file=.env src/main/index.ts",
		"build": "tsc",
		"start": "node dist/main/index.js",
		"migrate": "node dist/infra/database/migrate.js",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@11.3.0+sha256.5ade1ef51cf36441f4a00931eaf9003654689eba3684939f70d7576b2dfb8474",
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@fission-ai/openspec": "^1.3.1",
		"@types/node": "^25.9.1",
		"@types/node-cron": "^3.0.11",
		"@vitest/coverage-v8": "^4.1.7",
		"changelogen": "^0.6.2",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"vite": "^7.0.0",
		"vitest": "^4.1.7"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1053.0",
		"@casl/ability": "^7.0.0",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^11.2.0",
		"@fastify/helmet": "^13.0.2",
		"@fastify/multipart": "^10.0.0",
		"@fastify/rate-limit": "^10.3.0",
		"@fastify/swagger": "^9.7.0",
		"@fastify/swagger-ui": "^5.2.6",
		"better-auth": "^1.6.11",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.8.5",
		"node-cron": "^4.2.1",
		"postgres": "^3.4.9",
		"resend": "^6.12.3",
		"stripe": "^22.1.1",
		"zod": "^4.4.3"
	}
}
