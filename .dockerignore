# Dependencies (reinstalled fresh in each stage)
node_modules

# Build output (rebuilt in builder stage)
dist

# Git
.git
.gitignore

# Claude / IDE
.claude
.vscode
.idea

# Environment variables — never bake secrets into an image
.env
.env.local
.env.*.local

# Docker files (no need inside the image)
Dockerfile
docker-compose*.yml
.dockerignore

# Dev tooling not needed at build time
Makefile

# OS
.DS_Store
Thumbs.db

# Logs
*.log
pnpm-debug.log*

# Tests and coverage
coverage
**/*.test.ts
**/*.spec.ts

# TypeScript incremental cache
*.tsbuildinfo

# Markdown docs
*.md
