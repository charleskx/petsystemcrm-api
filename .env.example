# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3333
API_URL=http://localhost:3333

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/petsystemcrm

# ── Auth (better-auth) ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public URL for serving uploaded files (e.g. https://pub-xxx.r2.dev)
R2_PUBLIC_URL=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
# Webhook secret from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Google Maps ───────────────────────────────────────────────────────────────
# Used for address autocomplete endpoint
GOOGLE_MAPS_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000
